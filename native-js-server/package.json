    "mongoose": "^8.0.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.10.0",
    "@types/xml2js": "^0.4.14",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0"
  }
}
